{
  "@context": {
    "@vocab": "https://schema.org/",
    "un": "https://unstats.un.org/unsd/trade/",
    "comtrade": "https://comtradeapi.un.org/vocab/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "TradeDataset": "un:TradeDataset",
    "TradeRecord": "un:TradeRecord",
    "DataAvailability": "un:DataAvailability",

    "typeCode": {
      "@id": "comtrade:typeCode",
