    },
    "partnerDesc": {
      "@id": "comtrade:partnerDesc",
      "@type": "xsd:string"
    },
    "classificationCode": {
      "@id": "comtrade:classificationCode",
      "@type": "xsd:string"
    },
    "cmdCode": {
      "@id": "comtrade:cmdCode",
